# -----------------------------------------------------------------------------
# .gitignore de UnityEvents
# -----------------------------------------------------------------------------

# --- Archivos compilados ---
*.class
*.log
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# --- Herramientas / entornos varios ---
*.ctxt
.mtj.tmp/
hs_err_pid*
replay_pid*

# --- Gradle / Kotlin ---
.gradle/
build/
**/build/
!/**/src/**/build/
.kotlin/

# --- Android Studio / IntelliJ ---
.idea/
*.iml
captures/
.externalNativeBuild
.cxx/

# --- Android local config (NO commitear: contiene sdk.dir y secrets) ---
local.properties

# --- Firebase: claves de build descargadas de Firebase Console ---
# google-services.json es especifico del proyecto Firebase de cada equipo de desarrollo.
# Si trabajas en equipo, considera compartirlo de forma segura y dejarlo local.
# Para este proyecto academico lo mantenemos ignorado por defecto.
app/google-services.json

# --- macOS ---
.DS_Store
