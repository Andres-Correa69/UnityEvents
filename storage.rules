// Reglas iniciales de Firebase Storage para UnityEvents (Fase A).
//
// Aunque en Fase A todavia no subimos archivos, dejamos el servicio inicializado y sus
// reglas listas para Fase B/C (foto de perfil, imagenes de eventos, etc.).
//
// Principio: solo el propio usuario puede escribir en su carpeta personal /users/{uid}/;
// cualquier usuario autenticado puede leerla (asi aparece el avatar a otros).
//
// Publica con: firebase deploy --only storage

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Carpeta personal del usuario: escritura solo por el dueno, lectura para autenticados.
    match /users/{userId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Cualquier otro path queda cerrado hasta que las features que lo usen definan sus reglas.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
