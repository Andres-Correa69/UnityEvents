// Reglas de Firebase Storage para UnityEvents.
//
// Buckets usados:
//   /users/{uid}/avatar.jpg       → foto de perfil; solo el dueno escribe, cualquier autenticado lee.
//   /events/{uid}/{eventId}.jpg   → imagen del evento creado por el usuario {uid}.
//
// Publica con: firebase deploy --only storage
// (o pega este archivo manualmente en Storage -> Rules en Firebase Console).

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // --- Avatares de usuarios -----------------------------------------------
    match /users/{userId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // --- Imagenes de eventos ------------------------------------------------
    // El organizador de un evento sube la imagen al path events/{organizerId}/...
    match /events/{organizerId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == organizerId;
    }

    // --- Fallback ------------------------------------------------------------
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
