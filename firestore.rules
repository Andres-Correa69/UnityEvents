// Reglas de Cloud Firestore para UnityEvents (Fase B+).
//
// Principios:
// - Todas las lecturas / escrituras requieren autenticacion.
// - Los usuarios solo pueden modificar sus propios documentos; los moderadores tienen
//   privilegios extra (aprobar eventos, cambiar estado de reportes, marcar tickets usados).
//
// Estructura:
//   /users/{uid}
//   /users/{uid}/notifications/{id}
//   /events/{eventId}
//   /events/{eventId}/comments/{commentId}
//   /tickets/{ticketId}
//   /reports/{reportId}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    // Para decidir "es moderador" leemos el propio doc de usuario. El role se guarda
    // como string "USER" | "MODERATOR" | "ADMIN".
    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isModerator() {
      return isSignedIn() && role() in ['MODERATOR', 'ADMIN'];
    }

    // --- /users -------------------------------------------------------------
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSelf(userId);
      // Update: el dueno, un moderador, O cualquier autenticado que SOLO toque los
      // campos de reputacion (points, level, updatedAt). Esto permite que el sistema
      // de puntos se autoajuste cuando un usuario comenta tu evento, escanea tu ticket,
      // aprueba tu evento, etc. No pueden tocar displayName, role, email, etc.
      allow update: if isSelf(userId)
        || isModerator()
        || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['points', 'level', 'updatedAt']));
      allow delete: if false;

      // Subcoleccion /notifications.
      match /notifications/{notificationId} {
        // Leer/modificar: solo el destinatario.
        allow read, update, delete: if isSelf(userId);
        // Crear: cualquier autenticado (para que otros usuarios / repos puedan
        // notificar al dueno — ej. nuevo comentario, evento aprobado, etc.).
        allow create: if isSignedIn();
      }
    }

    // --- /events ------------------------------------------------------------
    match /events/{eventId} {
      // Cualquier autenticado puede leer; los moderadores ven tambien los PENDING/REJECTED.
      allow read: if isSignedIn();
      // El autor puede crear su evento (status inicial PENDING).
      allow create: if isSignedIn() && request.resource.data.organizerId == request.auth.uid
                    && request.resource.data.status == 'PENDING';
      // Update: el autor, un moderador, O cualquier autenticado que SOLO modifique
      // el contador denormalizado `attendeesCount` (para que otros usuarios puedan
      // comprar tickets sin ser organizadores).
      allow update: if isSignedIn() && (
        resource.data.organizerId == request.auth.uid ||
        isModerator() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['attendeesCount'])
      );
      // Delete: solo el autor o moderador.
      allow delete: if isSignedIn() &&
                    (resource.data.organizerId == request.auth.uid || isModerator());

      // Subcoleccion /comments.
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update: if isSignedIn() && (resource.data.authorId == request.auth.uid || isModerator());
        allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isModerator());
      }
    }

    // --- /tickets -----------------------------------------------------------
    match /tickets/{ticketId} {
      // Lee: el dueno del ticket, el organizador del evento (para escaneo) o un moderador.
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isModerator() ||
        get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizerId == request.auth.uid
      );
      // Crear: el propio usuario (para si mismo).
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Actualizar (marcar usado): organizador del evento o moderador.
      allow update: if isSignedIn() && (
        isModerator() ||
        get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizerId == request.auth.uid
      );
      allow delete: if false;
    }

    // --- /reports -----------------------------------------------------------
    match /reports/{reportId} {
      // Cualquier autenticado puede crear un reporte.
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      // Solo moderadores pueden leer / actualizar reportes.
      allow read, update: if isModerator();
      allow delete: if false;
    }

    // --- Fallback: todo lo demas denegado. ---------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
