<?xml version="1.0" encoding="utf-8"?>
<!--
    Tema XML base para Android.
    Como la app se construye 100% en Jetpack Compose + Material 3, este tema solo provee
    una base minima (sin action bar) para el launcher y el splash. El look real lo maneja
    `UnityEventsTheme` en core/theme/Theme.kt.
-->
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.UnityEvents" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Status bar transparente: Compose controla su apariencia con insets. -->
        <item name="android:statusBarColor" tools:targetApi="21">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
        <item name="android:navigationBarColor" tools:targetApi="21">@android:color/transparent</item>
    </style>
</resources>
